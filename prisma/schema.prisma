// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  plan                  String    @default("free") // "free" | "pro"
  storageUsedBytes      Float     @default(0)
  lemonCustomerId       String?   @unique
  lemonSubscriptionId   String?   @unique
  lemonPaidUntil        DateTime?

  worlds    World[]
  uploadedFiles         UploadedFile[]
}

model UploadedFile {
  id        String   @id @default(cuid())
  url       String   @unique
  size      Float
  fileName  String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  noteId    String?
  note      Note?    @relation(fields: [noteId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
}

model World {
  id          String   @id @default(cuid())
  name        String
  description String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  calendars     Calendar[]
  chapters      Chapter[]
  characters    Character[]
  locations     Location[]
  events        TimelineEvent[]
  stories       Story[]
  organizations Organization[]
  lores         Lore[]
  systems       WorldSystem[]
  objects       WorldObject[]
}

model Calendar {
  id        String   @id @default(cuid())
  name      String
  
  // Configuration stored as JSON to allow flexible structures (months, weekdays, leap rules)
  // Schema: { months: [], weekDays: [], yearSuffix: string, hoursInDay: number, ... }
  config    Json     

  // Current date pointer for this calendar
  // Schema: { year: number, monthIndex: number, day: number }
  currentDate Json?

  worldId   String
  world     World    @relation(fields: [worldId], references: [id], onDelete: Cascade)

  events    TimelineEvent[]

  createdAt DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

model TimelineEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  
  // Stored as JSON because custom dates don't map to standard Date objects
  // Schema: { year: number, monthIndex: number, day: number }
  startDate   Json
  endDate     Json
  duration    Int      @default(1) // in days

  // Optional: Link to specific story elements
  chapterId   String?
  chapter     Chapter? @relation(fields: [chapterId], references: [id])

  worldId     String
  world       World    @relation(fields: [worldId], references: [id], onDelete: Cascade)

  calendarId  String
  calendar    Calendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)

  appearances CharacterAppearance[]
  snapshots   CharacterSnapshot[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

model Chapter {
  id        String   @id @default(cuid())
  title     String
  order     Int      @default(0)
  content   String?  @db.Text
  wordCount Int      @default(0)
  status    String   @default("Draft") // Draft, Editing, Completed
  lastEdited DateTime @default(now())
  date      Json?
  
  worldId   String
  world     World    @relation(fields: [worldId], references: [id], onDelete: Cascade)

  storyId   String?
  story     Story?   @relation(fields: [storyId], references: [id], onDelete: Cascade)
  
  events    TimelineEvent[]
  characters Character[]
  locations  Location[]
  snapshots  CharacterSnapshot[]

  createdAt DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

model Story {
  id          String   @id @default(cuid())
  title       String
  genre       String?
  synopsis    String?  @db.Text
  status      String   @default("Draft") // Draft, Editing, Completed
  wordCount   Int      @default(0)
  lastEdited  DateTime @default(now())
  coverImage  String?
  tags        String[] // Array of tags
  
  worldId     String
  world       World    @relation(fields: [worldId], references: [id], onDelete: Cascade)
  
  chapters      Chapter[]
  characters    Character[]
  locations     Location[]
  notes         Note[]
  organizations Organization[]
  lores         Lore[]
  systems       WorldSystem[]
  objects       WorldObject[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

model Character {
  id          String   @id @default(cuid())
  name        String
  role        String?
  age         String?
  gender      String?
  species     String?
  occupation  String?
  personality String?  @db.Text
  backstory   String?  @db.Text
  avatarUrl   String?

  birthdate        Json?
  deathdate        Json?
  resurrectionDate Json?
  height           String?
  weight           String?
  hairColor        String?
  eyeColor         String?
  skinColor        String?
  birthplaceId     String?
  birthplace       Location? @relation("CharacterBirthplace", fields: [birthplaceId], references: [id], onDelete: SetNull)

  worldId     String
  world       World    @relation(fields: [worldId], references: [id], onDelete: Cascade)
  
  storyId     String?
  story       Story?   @relation(fields: [storyId], references: [id], onDelete: SetNull)
  chapters    Chapter[]

  relationships         CharacterRelationship[] @relation("CharacterSource")
  relatedTo             CharacterRelationship[] @relation("CharacterTarget")
  appearances           CharacterAppearance[]
  appearancesAsTarget   CharacterAppearance[] @relation("AppearanceTarget")
  snapshots             CharacterSnapshot[]
  organizationMemberships OrganizationMember[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

model CharacterRelationship {
  id           String    @id @default(cuid())
  type         String    // e.g., "Brother of", "Friend of", "Rival of", "Parent of"
  
  characterId  String
  character    Character @relation("CharacterSource", fields: [characterId], references: [id], onDelete: Cascade)
  
  targetId     String
  target       Character @relation("CharacterTarget", fields: [targetId], references: [id], onDelete: Cascade)
  
  @@unique([characterId, targetId, type])
}

model CharacterAppearance {
  id          String        @id @default(cuid())
  role        String        // e.g., "born", "died", "present", "fought"
  description String?       // Optional extra context on their appearance
  
  characterId String
  character   Character     @relation(fields: [characterId], references: [id], onDelete: Cascade)
  
  eventId     String
  event       TimelineEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  // Optional: another character involved in this event (e.g. "killed by", "married to")
  targetCharacterId String?
  targetCharacter   Character? @relation("AppearanceTarget", fields: [targetCharacterId], references: [id], onDelete: SetNull)
  
  @@unique([characterId, eventId, role])
}

model Location {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String?
  mapUrl      String?
  imageUrl    String?

  parentId    String?
  parent      Location?  @relation("LocationChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children    Location[] @relation("LocationChildren")

  worldId     String
  world       World    @relation(fields: [worldId], references: [id], onDelete: Cascade)
  
  storyId     String?
  story       Story?   @relation(fields: [storyId], references: [id], onDelete: SetNull)
  chapters    Chapter[]

  bornCharacters      Character[]         @relation("CharacterBirthplace")
  snapshotBirthplaces CharacterSnapshot[] @relation("SnapshotBirthplace")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}


model Note {
  id            String         @id @default(cuid())
  title         String
  content       String?        @db.Text
  type          String         @default("general") // "general" | "research" | "scratchpad"
  links         String[]       // Array of URLs
  fileUrl       String?
  fileName      String?
  fileSize      Float?
  
  uploadedFiles UploadedFile[]
  
  storyId       String
  story         Story          @relation(fields: [storyId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @default(now()) @updatedAt
}

model RateLimit {
  key       String   @id
  count     Int
  expiresAt DateTime

  @@index([expiresAt])
}

model CharacterSnapshot {
  id          String   @id @default(cuid())
  label       String                        // e.g. "After Curse", "Post-Timeskip"
  note        String?  @db.Text            // What changed and why

  // Full state copy
  name        String
  role        String?
  age         String?
  gender      String?
  species     String?
  occupation  String?
  personality String?  @db.Text
  backstory   String?  @db.Text
  avatarUrl   String?

  birthdate        Json?
  deathdate        Json?
  resurrectionDate Json?
  height           String?
  weight           String?
  hairColor        String?
  eyeColor         String?
  skinColor        String?
  birthplaceId     String?
  birthplace       Location? @relation("SnapshotBirthplace", fields: [birthplaceId], references: [id], onDelete: SetNull)

  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  // Optional trigger anchors
  eventId     String?
  event       TimelineEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  chapterId   String?
  chapter     Chapter?  @relation(fields: [chapterId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
}

// --- Organization ---
model Organization {
  id          String   @id @default(cuid())
  name        String
  type        String   @default("Faction") // free-form: Faction, Guild, Military Unit, etc.
  description String?  @db.Text
  imageUrl    String?
  tags        String[]

  parentId    String?
  parent      Organization?  @relation("OrgChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children    Organization[] @relation("OrgChildren")

  worldId     String
  world       World    @relation(fields: [worldId], references: [id], onDelete: Cascade)
  storyId     String?
  story       Story?   @relation(fields: [storyId], references: [id], onDelete: SetNull)

  members     OrganizationMember[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

model OrganizationMember {
  id             String       @id @default(cuid())
  role           String?      // free-form: Leader, Member, Agent, etc.

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  characterId    String
  character      Character    @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([organizationId, characterId])
}

// --- Lore ---
model Lore {
  id           String   @id @default(cuid())
  name         String
  category     String?  // free-form: Myth, History, Religion, Document, etc.
  description  String?  @db.Text
  imageUrl     String?
  referenceUrl String?
  tags         String[]

  worldId      String
  world        World    @relation(fields: [worldId], references: [id], onDelete: Cascade)
  storyId      String?
  story        Story?   @relation(fields: [storyId], references: [id], onDelete: SetNull)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
}

// --- WorldSystem ---
model WorldSystem {
  id           String   @id @default(cuid())
  name         String
  category     String?  // free-form: Magic, Economy, Law, Technology, etc.
  description  String?  @db.Text
  imageUrl     String?
  referenceUrl String?
  tags         String[]

  worldId      String
  world        World    @relation(fields: [worldId], references: [id], onDelete: Cascade)
  storyId      String?
  story        Story?   @relation(fields: [storyId], references: [id], onDelete: SetNull)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
}

// --- WorldObject ---
model WorldObject {
  id           String   @id @default(cuid())
  name         String
  category     String?  // free-form: Weapon, Relic, Artifact, Vehicle, etc.
  description  String?  @db.Text
  imageUrl     String?
  referenceUrl String?
  tags         String[]

  worldId      String
  world        World    @relation(fields: [worldId], references: [id], onDelete: Cascade)
  storyId      String?
  story        Story?   @relation(fields: [storyId], references: [id], onDelete: SetNull)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
}